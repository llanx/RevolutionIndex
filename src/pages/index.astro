---
import BaseLayout from '../layouts/BaseLayout.astro';
import FactorsBreakdown from '../components/FactorsBreakdown.astro';
import Gauge from '../components/Gauge.astro';
import TrendChart from '../components/TrendChart.astro';
import { ZONES, type CurrentData, type HistoryData, type FactorsData } from '../lib/data';

import currentRaw from '../../public/data/current.json';
import historyRaw from '../../public/data/history.json';
import factorsRaw from '../../public/data/factors.json';

const current = currentRaw as unknown as CurrentData;
const history = historyRaw as unknown as HistoryData;
const factors = factorsRaw as unknown as FactorsData;

// Format timestamp for display (static — runs at build time)
const dateDisplay = new Date(current.timestamp).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Enrich current factors with descriptions from factors.json
const enrichedFactors = current.factors.map(f => ({
  ...f,
  description: factors.factors.find(d => d.id === f.id)?.description ?? '',
}));

// Serialize data for client-side charts (Plan 02 will use these)
const chartLabels = JSON.stringify(history.entries.map(e => e.date));
const chartValues = JSON.stringify(history.entries.map(e => e.score));

const zoneColor = ZONES.find(z => z.label === current.zone)?.cssVar ?? 'var(--text-primary)';
---

<BaseLayout title="Revolution Index">
  <main class="dashboard">
    <!-- Hero section: gauge + score (above fold) -->
    <section class="dashboard-hero">
      <h1 class="sr-only">Revolution Index Dashboard</h1>

      <!-- Gauge mount point (Plan 02 injects D3 SVG here) -->
      <div
        id="gauge-mount"
        class="gauge-container"
        data-score={current.score}
        role="img"
        aria-label={`Revolution Index score: ${current.score} out of 100, ${current.zone}`}
      >
        <!-- D3 gauge renders here (Gauge.astro replaces this content) -->
      </div>

      <!-- Score and metadata -->
      <div class="score-display">{current.score}</div>
      <div class="zone-label" style={`color: ${zoneColor}`}>{current.zone}</div>
      <p class="timestamp">
        Last updated: <time datetime={current.timestamp}>{dateDisplay}</time>
      </p>
    </section>

    <!-- Below fold: trend chart + factors -->
    <div class="dashboard-lower">
      <!-- Trend chart section -->
      <section class="dashboard-section">
        <h2 class="section-title">Historical Trend</h2>
        <div class="chart-container">
          <canvas
            id="trend-chart"
            data-labels={chartLabels}
            data-values={chartValues}
          ></canvas>
        </div>
      </section>

      <!-- Factors section -->
      <section class="dashboard-section">
        <h2 class="section-title">Contributing Factors</h2>
        <FactorsBreakdown factors={enrichedFactors} />
      </section>
    </div>

    <!-- Disclaimer -->
    <!-- TODO: review disclaimer copy before launch -->
    <section class="disclaimer" aria-label="Score disclaimer">
      <p>
        <strong>Note:</strong> The Revolution Index is a data-driven indicator derived from
        publicly available social, economic, and political signals. It is <em>not</em> a prediction
        of future events, a call to action, or a statement of political advocacy. The score
        reflects historical patterns and structural indicators — it does not forecast specific
        outcomes. The data displayed is currently based on demonstration data and does not reflect
        real-time research.
      </p>
    </section>

    <!-- About -->
    <section class="about" aria-label="About this project">
      <h2 class="section-title">About</h2>
      <p>
        The Revolution Index is an analytical project that tracks structural indicators of political
        instability in the United States. By aggregating publicly available economic, social, and
        political data into a single composite score, it aims to make complex dynamics accessible
        and understandable at a glance. This is a research and transparency tool — not a political
        statement. For details on how the score is constructed, see the
        <a href="/methodology">Methodology</a> page.
      </p>
    </section>

    <!-- Client-side chart scripts (bundled by Astro) -->
    <Gauge />
    <TrendChart />
  </main>
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
