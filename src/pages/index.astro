---
import BaseLayout from '../layouts/BaseLayout.astro';
import FactorsBreakdown from '../components/FactorsBreakdown.astro';
import Gauge from '../components/Gauge.astro';
import TrendChart from '../components/TrendChart.astro';
import '../styles/dashboard.css';
import { ZONES, type CurrentData, type HistoryData, type FactorsData, type BenchmarksData, type BenchmarkFactorId } from '../lib/data';

import currentRaw from '../../public/data/current.json';
import historyRaw from '../../public/data/history.json';
import factorsRaw from '../../public/data/factors.json';
import benchmarksRaw from '../../public/data/benchmarks.json';

const current = currentRaw as unknown as CurrentData;
const history = historyRaw as unknown as HistoryData;
const factors = factorsRaw as unknown as FactorsData;
const { benchmarks } = benchmarksRaw as unknown as BenchmarksData;

// Format timestamp for display (static, runs at build time)
const dateDisplay = new Date(current.timestamp).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Enrich current factors with descriptions + historical sparkline data from factors.json
const detailMap = new Map(factors.factors.map(d => [d.id, d]));
const enrichedFactors = current.factors.map(f => {
  const detail = detailMap.get(f.id);
  return {
    ...f,
    description: detail?.description ?? '',
    historical: detail?.historical ?? [],
  };
});

// Serialize data for client-side charts (filter to 1947+ to exclude zero-score pre-data era)
const MIN_HISTORY_YEAR = 1947;
const filteredEntries = history.entries.filter(e => new Date(e.date).getFullYear() >= MIN_HISTORY_YEAR);
const chartLabels = JSON.stringify(filteredEntries.map(e => e.date));
const chartValues = JSON.stringify(filteredEntries.map(e => e.score));

// Single zone lookup (Fix 4: was two separate ZONES.find calls)
const currentZone = ZONES.find(z => z.label === current.zone);
const zoneColor = currentZone?.cssVar ?? 'var(--text-primary)';
const zoneHex = currentZone?.color ?? '#f4a261';

// Model metadata for meta strip
const ci = current._bootstrap_ci;
const ciLabel = ci ? `90% CI: ${Math.round(ci.lower)}\u2013${Math.round(ci.upper)}` : null;
const modelsRun = current._models_run?.length ?? 0;
const modelsExpected = current._models_expected ?? 5;
const dataCoverage = current._data_coverage != null ? Math.round(current._data_coverage * 100) : null;
const variableCount = 41;

// Prepare gauge benchmark markers (Tier 1 only, 5 max to avoid clutter)
const tier1Ids = ['france-1789', 'russia-1917', 'iran-1979', 'arab-spring-2010', 'nepal-2025'];
const gaugeMarkers = JSON.stringify(
  benchmarks
    .filter(b => tier1Ids.includes(b.id))
    .map(b => ({ label: `${b.country} ${b.year}`, score: b.composite_estimate }))
);

// Build historical comparison insights for teaser
const usEconomicStress = current.factors.find(f => f.id === 'economic_stress')?.value ?? 0;
const usInstitutionalQuality = current.factors.find(f => f.id === 'institutional_quality')?.value ?? 0;

const insights: { text: string; severity: 'exceeds' | 'approaching' }[] = [];

for (const rev of benchmarks) {
  const histQuality = rev.factors.institutional_quality.value;
  if (usInstitutionalQuality < histQuality) {
    insights.push({
      text: `US institutional quality is lower than pre-revolution ${rev.country} (${rev.year})`,
      severity: 'exceeds',
    });
  }
  const histEcon = rev.factors.economic_stress.value;
  if (usEconomicStress > histEcon - 0.10 && usEconomicStress <= histEcon) {
    insights.push({
      text: `US economic stress is approaching ${rev.country} (${rev.year}) levels`,
      severity: 'approaching',
    });
  }
}

const topInsights = insights.slice(0, 3);

// Zone-specific editorial deck text
const zoneDeck: Record<string, string> = {
  'Stable': 'within historical norms; no significant structural pressures detected.',
  'Elevated Tension': 'where structural pressures are building but haven\u2019t reached critical mass.',
  'Crisis Territory': 'a range historically associated with severe political instability.',
  'Revolution Territory': 'a level that has preceded revolutionary upheaval in comparable nations.',
};

// Build benchmark markers for factor bars
type BarBenchmarkMarker = { label: string; value: number };
const factorBenchmarks = new Map<string, BarBenchmarkMarker>();
const comparedFactorIds: BenchmarkFactorId[] = ['economic_stress', 'political_polarization', 'social_mobilization', 'institutional_quality', 'information_media'];

for (const factorId of comparedFactorIds) {
  let extreme: BarBenchmarkMarker | null = null;
  for (const rev of benchmarks) {
    const fData = rev.factors[factorId];
    if (!fData) continue;
    if (factorId === 'institutional_quality') {
      if (!extreme || fData.value < extreme.value) {
        extreme = { label: `${rev.country} ${rev.year}`, value: fData.value };
      }
    } else {
      if (!extreme || fData.value > extreme.value) {
        extreme = { label: `${rev.country} ${rev.year}`, value: fData.value };
      }
    }
  }
  if (extreme) factorBenchmarks.set(factorId, extreme);
}
---

<BaseLayout title="Revolution Index">
  <main class="dashboard">
    <!-- Hero section: editorial headline + gauge illustration (above fold) -->
    <section class="dashboard-hero">
      <h1 class="sr-only">Revolution Index Dashboard</h1>

      <!-- Editorial headline block -->
      <div class="hero-editorial">
        <p class="hero-kicker">The Revolution Index</p>
        <h2 class="hero-headline">
          America Sits at <span class="hero-score-inline" id="score-display" data-target={current.score}>{current.score}</span>
        </h2>
        <p class="hero-deck">
          The composite instability score places the United States in
          <span class="hero-zone-inline" style={`color: ${zoneColor}`}>{current.zone}</span>
          , {zoneDeck[current.zone] ?? 'a level reflecting current structural conditions.'}
        </p>
        <p class="hero-timestamp">
          <span class="live-dot"></span>
          Last updated: <time datetime={current.timestamp}>{dateDisplay}</time>
        </p>
        <div class="model-meta-strip">
          {ciLabel && <span class="meta-pill" title="Bootstrap 90% confidence interval">{ciLabel}</span>}
          <span class="meta-pill" title={`${modelsRun} of ${modelsExpected} models contributed`}>{modelsRun}-model ensemble</span>
          <span class="meta-pill" title="Total input variables across five domains">{variableCount} variables</span>
          {dataCoverage != null && <span class="meta-pill" title="Percentage of variables with available data">{dataCoverage}% data coverage</span>}
        </div>
      </div>

      <!-- Gauge as editorial illustration -->
      <div class="hero-gauge-frame">
        <!-- Zone-colored ambient glow behind gauge -->
        <div class="gauge-ambient-glow" style={`--zone-glow-color: ${zoneHex}`}></div>

        <!-- Gauge mount point -->
        <div
          id="gauge-mount"
          class="gauge-container"
          data-score={current.score}
          data-benchmarks={gaugeMarkers}
          role="img"
          aria-label={`Revolution Index score: ${current.score} out of 100, ${current.zone}`}
        >
        </div>
        <p class="gauge-caption">
          Composite score across five structural indicators, benchmarked against historical revolutions.
        </p>
      </div>

      <!-- Subtle scroll cue -->
      <div class="hero-scroll-cue" aria-hidden="true">
        <span class="scroll-cue-line"></span>
      </div>
    </section>

    <!-- Particle canvas (behind content, above background) -->
    <canvas id="particle-canvas" aria-hidden="true"></canvas>

    <!-- Below fold: trend chart + factors -->
    <div class="dashboard-lower">
      <!-- Trend chart section -->
      <section class="dashboard-section scroll-reveal">
        <h2 class="section-title">Historical Trend</h2>
        <div class="chart-container" id="trend-chart-container">
          <canvas
            id="trend-chart"
            data-labels={chartLabels}
            data-values={chartValues}
          ></canvas>
        </div>
      </section>

      <!-- Factors section -->
      <section class="dashboard-section scroll-reveal" style="--reveal-delay: 0.15s">
        <h2 class="section-title">Contributing Factors</h2>
        <FactorsBreakdown factors={enrichedFactors} benchmarks={Object.fromEntries(factorBenchmarks)} />
      </section>
    </div>

    <!-- Historical Context Teaser -->
    {topInsights.length > 0 && (
      <section class="history-teaser scroll-reveal" aria-label="Historical context" style="--reveal-delay: 0.1s">
        <h2 class="section-title">Historical Context</h2>
        <p class="teaser-intro">
          How do current US conditions compare to the preconditions of history's major revolutions?
        </p>
        <ul class="teaser-insights">
          {topInsights.map((insight) => (
            <li class={`teaser-insight teaser-${insight.severity}`}>
              {insight.text}
            </li>
          ))}
        </ul>
        <a href="/history" class="teaser-link">Explore all historical comparisons &rarr;</a>
      </section>
    )}

    <!-- Disclaimer -->
    <section class="disclaimer scroll-reveal" aria-label="Score disclaimer" style="--reveal-delay: 0.15s">
      <p>
        <strong>Note:</strong> The Revolution Index is derived from 41 publicly available
        indicators from sources including FRED, V-Dem, VoteView, ANES, and ACLED across five
        structural domains. It is <em>not</em> a prediction of future events, a call to action,
        or a statement of political advocacy. The score reflects historical patterns and structural
        conditions. It does not forecast specific outcomes.
      </p>
    </section>

    <!-- About -->
    <section class="about scroll-reveal" aria-label="About this project" style="--reveal-delay: 0.2s">
      <h2 class="section-title">About</h2>
      <p>
        The Revolution Index uses a five-model scoring ensemble covering Economic Stress,
        Political Polarization, Institutional Quality, Social Mobilization, and Information &amp;
        Media. The 41 input variables are combined into a calibrated 0-100 composite score with
        bootstrap confidence intervals (n=1,000). This is a research and transparency tool, not a
        political statement. For details on how the score is constructed, see the
        <a href="/methodology">Methodology</a> page.
      </p>
    </section>

    <!-- Client-side chart scripts (bundled by Astro) -->
    <Gauge />
    <TrendChart />
  </main>
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>

<script>
  // AbortController for cleaning up listeners/animations between View Transitions
  let cleanupController: AbortController | null = null;

  function animateScoreCounter(scoreEl: HTMLElement, target: number, signal: AbortSignal) {
    scoreEl.textContent = '0';

    window.addEventListener('gauge-needle-start', ((e: CustomEvent) => {
      const counterDelay = 200;  // Needle leads by 200ms
      const duration = e.detail.sweepDuration - counterDelay;  // 700ms to land with needle

      setTimeout(() => {
        if (signal.aborted) return;
        const start = performance.now();

        function tick(now: number) {
          if (signal.aborted) return;
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - (1 - progress) * (1 - progress);
          scoreEl.textContent = String(Math.round(eased * target));

          if (progress < 1) {
            requestAnimationFrame(tick);
          }
        }

        requestAnimationFrame(tick);
      }, counterDelay);
    }) as EventListener, { signal });
  }

  function initScrollReveals(signal: AbortSignal, prefersReducedMotion: boolean) {
    const revealEls = document.querySelectorAll('.scroll-reveal');

    if (revealEls.length > 0 && !prefersReducedMotion) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              (entry.target as HTMLElement).classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      revealEls.forEach((el) => observer.observe(el));
      signal.addEventListener('abort', () => observer.disconnect());
    } else {
      revealEls.forEach((el) => (el as HTMLElement).classList.add('revealed'));
    }
  }

  function initFactorBarAnimations(signal: AbortSignal, prefersReducedMotion: boolean) {
    const factorBars = document.querySelectorAll('.factor-bar-fill[data-width]');
    if (factorBars.length === 0 || prefersReducedMotion) return;

    factorBars.forEach((bar) => {
      (bar as HTMLElement).style.width = '0%';
    });

    const barObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.style.width = el.dataset.width!;
            barObserver.unobserve(el);
          }
        });
      },
      { threshold: 0.1 }
    );

    factorBars.forEach((bar, i) => {
      const el = bar as HTMLElement;
      el.style.transitionDelay = `${i * 100}ms`;
      barObserver.observe(el);
    });
    signal.addEventListener('abort', () => barObserver.disconnect());
  }

  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    size: number;
    opacity: number;
    life: number;
    maxLife: number;
  }

  function initParticleSystem(canvas: HTMLCanvasElement, score: number, signal: AbortSignal) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = window.innerWidth;
    let height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;

    const particleCount = Math.floor(12 + (score / 100) * 30);
    const baseSpeed = 0.2 + (score / 100) * 0.5;

    let particleColor: string;
    if (score <= 25) particleColor = 'rgba(64, 145, 108,';
    else if (score <= 50) particleColor = 'rgba(244, 162, 97,';
    else if (score <= 75) particleColor = 'rgba(231, 111, 81,';
    else particleColor = 'rgba(193, 18, 31,';

    function spawnParticle(): Particle {
      return {
        x: Math.random() * width,
        y: height + 10,
        vx: (Math.random() - 0.5) * 0.4,
        vy: -(baseSpeed + Math.random() * baseSpeed),
        size: 1 + Math.random() * 2,
        opacity: 0.1 + Math.random() * 0.3,
        life: 0,
        maxLife: 200 + Math.random() * 300,
      };
    }

    const particles: Particle[] = [];
    for (let i = 0; i < particleCount; i++) {
      const p = spawnParticle();
      p.y = Math.random() * height;
      p.life = Math.random() * p.maxLife;
      particles.push(p);
    }

    function animate() {
      if (signal.aborted) return;
      ctx!.clearRect(0, 0, width, height);

      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        p.life++;

        const lifeRatio = p.life / p.maxLife;
        let alpha = p.opacity;
        if (lifeRatio < 0.1) alpha *= lifeRatio / 0.1;
        else if (lifeRatio > 0.8) alpha *= (1 - lifeRatio) / 0.2;

        if (p.life >= p.maxLife || p.y < -10) {
          particles[i] = spawnParticle();
          continue;
        }

        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx!.fillStyle = `${particleColor} ${alpha})`;
        ctx!.fill();
      }

      requestAnimationFrame(animate);
    }

    animate();

    window.addEventListener('resize', () => {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    }, { signal });
  }

  function initDashboardAnimations() {
    cleanupController?.abort();
    cleanupController = new AbortController();
    const { signal } = cleanupController;

    const scoreEl = document.getElementById('score-display');
    if (!scoreEl) return;

    const target = Number(scoreEl.dataset.target ?? 0);
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReducedMotion) {
      animateScoreCounter(scoreEl, target, signal);
    }

    initScrollReveals(signal, prefersReducedMotion);
    initFactorBarAnimations(signal, prefersReducedMotion);

    const particleCanvas = document.getElementById('particle-canvas') as HTMLCanvasElement | null;
    if (particleCanvas && !prefersReducedMotion) {
      initParticleSystem(particleCanvas, target, signal);
    }
  }

  initDashboardAnimations();
  document.addEventListener('astro:after-swap', initDashboardAnimations);
</script>
