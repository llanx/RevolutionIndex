---
import '../styles/global.css';

export interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Revolution Index - Real-time political stability dashboard" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
