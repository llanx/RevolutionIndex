---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'A data-driven dashboard tracking the probability of revolutionary political change in the United States.',
  ogImage = '/og.svg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'http://localhost:4321');
const ogImageURL = new URL(ogImage, Astro.site ?? 'http://localhost:4321');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Revolution Index" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <!-- TODO: Convert og.svg to og.png for maximum social media compatibility before launch -->
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter/X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <title>{title}</title>
  </head>
  <body>
    <nav class="site-nav" aria-label="Main navigation">
      <div class="site-nav-inner">
        <a href="/" class="nav-logo">Revolution Index</a>
        <div class="nav-links">
          <a href="/">Dashboard</a>
          <a href="/history">History</a>
          <a href="/methodology">Methodology</a>
        </div>
      </div>
    </nav>
    <slot />
  </body>
</html>
