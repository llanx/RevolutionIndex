<script>
import * as d3 from 'd3';
import { ZONES } from '../lib/data';

const mount = document.getElementById('gauge-mount');
if (!mount) throw new Error('Gauge mount element not found');

const score = Number(mount.dataset.score);

// Clear placeholder content
mount.innerHTML = '';

// Gauge layout — sized for a 400px-wide semicircle with a 60px-thick arc band
const gauge = { width: 400, height: 240, outerR: 160, innerR: 100, bottomPad: 30 };
const cx = gauge.width / 2;
const cy = gauge.height - gauge.bottomPad;

// Map 0-100 score to semicircle angle (radians)
// Left = -PI/2 (score 0), Right = +PI/2 (score 100)
function valueToAngle(v: number): number {
  return ((v / 100) - 0.5) * Math.PI;
}

const arcGen = d3.arc();

const svg = d3.select(mount)
  .append('svg')
  .attr('viewBox', `0 0 ${gauge.width} ${gauge.height}`)
  .attr('aria-hidden', 'true')  // accessibility label on container div
  .style('width', '100%')
  .style('height', 'auto');

const g = svg.append('g')
  .attr('transform', `translate(${cx},${cy})`);

// Draw zone arcs
ZONES.forEach(z => {
  g.append('path')
    .attr('d', arcGen({
      innerRadius: gauge.innerR,
      outerRadius: gauge.outerR,
      startAngle: valueToAngle(z.start),
      endAngle: valueToAngle(z.end),
    }))
    .attr('fill', z.color);
});

// Draw tick marks at zone boundaries (25, 50, 75)
[25, 50, 75].forEach(tick => {
  const angle = valueToAngle(tick);
  const x1 = (gauge.outerR + 5) * Math.sin(angle);
  const y1 = -(gauge.outerR + 5) * Math.cos(angle);
  const x2 = (gauge.outerR - 5) * Math.sin(angle);
  const y2 = -(gauge.outerR - 5) * Math.cos(angle);
  g.append('line')
    .attr('x1', x1).attr('y1', y1)
    .attr('x2', x2).attr('y2', y2)
    .attr('stroke', '#666')
    .attr('stroke-width', 2);
});

// Draw needle
const needleAngle = valueToAngle(score);
const needleLength = gauge.outerR - 15;
const tipX = needleLength * Math.sin(needleAngle);
const tipY = -needleLength * Math.cos(needleAngle);

// Needle base (triangle shape)
const baseHalfWidth = 6;
const leftAngle = needleAngle - Math.PI / 2;
const rightAngle = needleAngle + Math.PI / 2;
const lx = baseHalfWidth * Math.sin(leftAngle);
const ly = -baseHalfWidth * Math.cos(leftAngle);
const rx = baseHalfWidth * Math.sin(rightAngle);
const ry = -baseHalfWidth * Math.cos(rightAngle);

g.append('path')
  .attr('d', `M ${lx} ${ly} L ${tipX} ${tipY} L ${rx} ${ry} Z`)
  .attr('fill', '#f5f5f5');

// Center pin
g.append('circle')
  .attr('r', 8)
  .attr('fill', '#f5f5f5');

// Min/max labels
g.append('text')
  .attr('x', -(gauge.outerR + 15))
  .attr('y', 15)
  .attr('fill', '#a0a0a0')
  .attr('font-size', '12px')
  .attr('text-anchor', 'middle')
  .text('0');

g.append('text')
  .attr('x', gauge.outerR + 15)
  .attr('y', 15)
  .attr('fill', '#a0a0a0')
  .attr('font-size', '12px')
  .attr('text-anchor', 'middle')
  .text('100');

// Draw historical revolution benchmark markers on the outer arc
const benchmarksAttr = mount.dataset.benchmarks;
if (benchmarksAttr) {
  try {
    const markers: { label: string; score: number }[] = JSON.parse(benchmarksAttr);
    markers.forEach(m => {
      const mAngle = valueToAngle(m.score);
      const markerR = gauge.outerR + 8;
      const mx = markerR * Math.sin(mAngle);
      const my = -markerR * Math.cos(mAngle);

      // Tick line
      const innerTick = (gauge.outerR + 2) * Math.sin(mAngle);
      const outerTick = (gauge.outerR + 14) * Math.sin(mAngle);
      const innerTickY = -(gauge.outerR + 2) * Math.cos(mAngle);
      const outerTickY = -(gauge.outerR + 14) * Math.cos(mAngle);

      g.append('line')
        .attr('x1', innerTick).attr('y1', innerTickY)
        .attr('x2', outerTick).attr('y2', outerTickY)
        .attr('stroke', '#a0a0a0')
        .attr('stroke-width', 1)
        .attr('opacity', 0.6);

      // Label
      const labelR = gauge.outerR + 22;
      const lx = labelR * Math.sin(mAngle);
      const ly = -labelR * Math.cos(mAngle);
      const angleDeg = (mAngle * 180) / Math.PI;

      g.append('text')
        .attr('x', lx)
        .attr('y', ly)
        .attr('fill', '#a0a0a0')
        .attr('font-size', '8px')
        .attr('text-anchor', angleDeg < 0 ? 'end' : angleDeg > 0 ? 'start' : 'middle')
        .attr('dominant-baseline', 'middle')
        .attr('opacity', 0.7)
        .text(m.label);
    });
  } catch (e) {
    // Silently skip if benchmark data is malformed
  }
}
</script>
