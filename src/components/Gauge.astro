<script>
import * as d3 from 'd3';
import { ZONES } from '../lib/data';

interface GaugeConfig {
  width: number;
  height: number;
  outerR: number;
  innerR: number;
  bottomPad: number;
}

function valueToAngle(v: number): number {
  return ((v / 100) - 0.5) * Math.PI;
}

function createSvgFilters(defs: d3.Selection<SVGDefsElement, unknown, null, undefined>) {
  // Zone glow filter
  const glowFilter = defs.append('filter')
    .attr('id', 'zone-glow')
    .attr('x', '-50%').attr('y', '-50%')
    .attr('width', '200%').attr('height', '200%');
  glowFilter.append('feGaussianBlur')
    .attr('in', 'SourceGraphic')
    .attr('stdDeviation', '3')
    .attr('result', 'blur');
  glowFilter.append('feComposite')
    .attr('in', 'SourceGraphic')
    .attr('in2', 'blur')
    .attr('operator', 'over');

  // Needle tip glow filter
  const tipGlow = defs.append('filter')
    .attr('id', 'needle-glow')
    .attr('x', '-200%').attr('y', '-200%')
    .attr('width', '500%').attr('height', '500%');
  tipGlow.append('feGaussianBlur')
    .attr('in', 'SourceGraphic')
    .attr('stdDeviation', '5')
    .attr('result', 'blur');
  tipGlow.append('feComposite')
    .attr('in', 'SourceGraphic')
    .attr('in2', 'blur')
    .attr('operator', 'over');
}

function drawZoneArcs(
  g: d3.Selection<SVGGElement, unknown, null, undefined>,
  gauge: GaugeConfig,
  currentZoneLabel: string,
  prefersReducedMotion: boolean,
  arcStagger: number,
  arcDuration: number,
) {
  const arcGen = d3.arc();
  const GAP = 0.012; // ~0.7 degrees in radians

  ZONES.forEach((z, i) => {
    const rawStart = valueToAngle(z.start);
    const rawEnd = valueToAngle(z.end);
    const startAngle = rawStart + (i === 0 ? 0 : GAP);
    const endAngle = rawEnd - (i === ZONES.length - 1 ? 0 : GAP);
    const isActive = z.label === currentZoneLabel;

    const arc = g.append('path')
      .attr('fill', z.color)
      .attr('opacity', isActive ? 1 : 0.65);

    if (isActive) {
      arc.attr('filter', 'url(#zone-glow)');
    }

    if (prefersReducedMotion) {
      arc.attr('d', arcGen({
        innerRadius: gauge.innerR,
        outerRadius: gauge.outerR,
        startAngle,
        endAngle,
      }));
    } else {
      arc.attr('d', arcGen({
        innerRadius: gauge.innerR,
        outerRadius: gauge.outerR,
        startAngle,
        endAngle: startAngle,
      }));

      arc.transition()
        .delay(i * arcStagger)
        .duration(arcDuration)
        .ease(d3.easeQuadOut)
        .attrTween('d', () => {
          const interp = d3.interpolate(startAngle, endAngle);
          return (t: number) => arcGen({
            innerRadius: gauge.innerR,
            outerRadius: gauge.outerR,
            startAngle,
            endAngle: interp(t),
          }) ?? '';
        });
    }
  });
}

function drawTickMarks(
  g: d3.Selection<SVGGElement, unknown, null, undefined>,
  gauge: GaugeConfig,
  prefersReducedMotion: boolean,
  needleDelay: number,
) {
  [25, 50, 75].forEach(tick => {
    const angle = valueToAngle(tick);
    const x1 = (gauge.outerR + 5) * Math.sin(angle);
    const y1 = -(gauge.outerR + 5) * Math.cos(angle);
    const x2 = (gauge.outerR - 5) * Math.sin(angle);
    const y2 = -(gauge.outerR - 5) * Math.cos(angle);

    const line = g.append('line')
      .attr('x1', x1).attr('y1', y1)
      .attr('x2', x2).attr('y2', y2)
      .attr('stroke', '#666')
      .attr('stroke-width', 2);

    if (!prefersReducedMotion) {
      line.attr('opacity', 0)
        .transition()
        .delay(needleDelay - 200)
        .duration(300)
        .attr('opacity', 1);
    }
  });
}

function drawNeedle(
  g: d3.Selection<SVGGElement, unknown, null, undefined>,
  gauge: GaugeConfig,
  score: number,
  zoneColor: string,
  prefersReducedMotion: boolean,
  needleDelay: number,
  needleDuration: number,
) {
  const targetAngle = valueToAngle(score);
  const originAngle = valueToAngle(0);
  const needleLength = gauge.outerR - 15;

  function needlePath(angle: number): string {
    const tipX = needleLength * Math.sin(angle);
    const tipY = -needleLength * Math.cos(angle);
    const baseHalf = 6;
    const lAngle = angle - Math.PI / 2;
    const rAngle = angle + Math.PI / 2;
    const lx = baseHalf * Math.sin(lAngle);
    const ly = -baseHalf * Math.cos(lAngle);
    const rx = baseHalf * Math.sin(rAngle);
    const ry = -baseHalf * Math.cos(rAngle);
    return `M ${lx} ${ly} L ${tipX} ${tipY} L ${rx} ${ry} Z`;
  }

  function needleTipPos(angle: number): { x: number; y: number } {
    return {
      x: needleLength * Math.sin(angle),
      y: -needleLength * Math.cos(angle),
    };
  }

  const needle = g.append('path')
    .attr('fill', '#f5f5f5')
    .attr('d', needlePath(prefersReducedMotion ? targetAngle : originAngle));

  // Glowing tip circle
  const tipPos = needleTipPos(prefersReducedMotion ? targetAngle : originAngle);
  const needleTip = g.append('circle')
    .attr('r', 5)
    .attr('fill', zoneColor)
    .attr('filter', 'url(#needle-glow)')
    .attr('cx', tipPos.x)
    .attr('cy', tipPos.y)
    .attr('opacity', prefersReducedMotion ? 0.7 : 0);

  if (!prefersReducedMotion) {
    // Two-phase animation: fast sweep with slight overshoot, then gentle settle
    const overshootAngle = originAngle + (targetAngle - originAngle) * 1.04;
    const sweepInterp = d3.interpolate(originAngle, overshootAngle);
    const settleInterp = d3.interpolate(overshootAngle, targetAngle);

    const sweepDuration = 900;
    const settleDuration = 300;

    // Signal counter to start synced animation
    setTimeout(() => {
      window.dispatchEvent(new CustomEvent('gauge-needle-start', {
        detail: { sweepDuration }
      }));
    }, needleDelay);

    // Phase 1: Sweep to overshoot
    needle.transition()
      .delay(needleDelay)
      .duration(sweepDuration)
      .ease(d3.easeQuadOut)
      .attrTween('d', () => (t: number) => needlePath(sweepInterp(t)))
      .transition()  // Phase 2: Settle back
      .duration(settleDuration)
      .ease(d3.easeCubicInOut)
      .attrTween('d', () => (t: number) => needlePath(settleInterp(t)));

    // Tip glow follows same two-phase motion
    needleTip.transition()
      .delay(needleDelay)
      .duration(sweepDuration)
      .ease(d3.easeQuadOut)
      .attrTween('cx', () => (t: number) => String(needleTipPos(sweepInterp(t)).x))
      .attrTween('cy', () => (t: number) => String(needleTipPos(sweepInterp(t)).y))
      .attr('opacity', 0.7)
      .transition()  // Phase 2: Settle back
      .duration(settleDuration)
      .ease(d3.easeCubicInOut)
      .attrTween('cx', () => (t: number) => String(needleTipPos(settleInterp(t)).x))
      .attrTween('cy', () => (t: number) => String(needleTipPos(settleInterp(t)).y));

    // Add pulse class after animation settles
    setTimeout(() => {
      const el = needleTip.node();
      if (el) el.classList.add('needle-tip-pulse');
    }, needleDelay + needleDuration + 200);
  }

  // Center pin (on top of needle)
  g.append('circle')
    .attr('r', 8)
    .attr('fill', '#f5f5f5');
}

function drawLabels(
  g: d3.Selection<SVGGElement, unknown, null, undefined>,
  gauge: GaugeConfig,
) {
  g.append('text')
    .attr('x', -(gauge.outerR + 15))
    .attr('y', 15)
    .attr('fill', '#a0a0a0')
    .attr('font-size', '12px')
    .attr('text-anchor', 'middle')
    .text('0');

  g.append('text')
    .attr('x', gauge.outerR + 15)
    .attr('y', 15)
    .attr('fill', '#a0a0a0')
    .attr('font-size', '12px')
    .attr('text-anchor', 'middle')
    .text('100');
}

function drawBenchmarkMarkers(
  g: d3.Selection<SVGGElement, unknown, null, undefined>,
  gauge: GaugeConfig,
  benchmarksAttr: string | undefined,
  prefersReducedMotion: boolean,
  markerBaseDelay: number,
) {
  if (!benchmarksAttr) return;

  try {
    const markers: { label: string; score: number }[] = JSON.parse(benchmarksAttr);

    markers.forEach((m, i) => {
      const mAngle = valueToAngle(m.score);
      const innerTick = (gauge.outerR + 2) * Math.sin(mAngle);
      const outerTick = (gauge.outerR + 14) * Math.sin(mAngle);
      const innerTickY = -(gauge.outerR + 2) * Math.cos(mAngle);
      const outerTickY = -(gauge.outerR + 14) * Math.cos(mAngle);

      const markerG = g.append('g');

      const line = markerG.append('line')
        .attr('x1', innerTick).attr('y1', innerTickY)
        .attr('x2', outerTick).attr('y2', outerTickY)
        .attr('stroke', '#a0a0a0')
        .attr('stroke-width', 1);

      const labelR = gauge.outerR + 22;
      const lx = labelR * Math.sin(mAngle);
      const ly = -labelR * Math.cos(mAngle);
      const angleDeg = (mAngle * 180) / Math.PI;

      const text = markerG.append('text')
        .attr('x', lx)
        .attr('y', ly)
        .attr('fill', '#a0a0a0')
        .attr('font-size', '8px')
        .attr('text-anchor', angleDeg < 0 ? 'end' : angleDeg > 0 ? 'start' : 'middle')
        .attr('dominant-baseline', 'middle')
        .text(m.label);

      if (prefersReducedMotion) {
        line.attr('opacity', 0.6);
        text.attr('opacity', 0.7);
      } else {
        markerG.attr('opacity', 0)
          .style('transform', 'scale(0.8)')
          .style('transform-origin', `${lx}px ${ly}px`);

        markerG.transition()
          .delay(markerBaseDelay + i * 180)
          .duration(400)
          .ease(d3.easeBackOut.overshoot(1.5))
          .attr('opacity', 1)
          .style('transform', 'scale(1)');

        line.attr('opacity', 0.6);
        text.attr('opacity', 0.7);
      }
    });
  } catch (e) {
    // Silently skip if benchmark data is malformed
  }
}

function drawTrack(
  g: d3.Selection<SVGGElement, unknown, null, undefined>,
  gauge: GaugeConfig,
) {
  const trackArc = d3.arc()({
    innerRadius: gauge.innerR,
    outerRadius: gauge.outerR,
    startAngle: valueToAngle(0),
    endAngle: valueToAngle(100),
  });
  g.append('path')
    .attr('d', trackArc)
    .attr('fill', '#1a1a1a');
}

function drawBezelRings(
  g: d3.Selection<SVGGElement, unknown, null, undefined>,
  gauge: GaugeConfig,
) {
  const outerBezel = d3.arc()({
    innerRadius: gauge.outerR + 1,
    outerRadius: gauge.outerR + 2,
    startAngle: valueToAngle(0),
    endAngle: valueToAngle(100),
  });
  g.append('path')
    .attr('d', outerBezel)
    .attr('fill', 'rgba(255, 255, 255, 0.08)');

  const innerBezel = d3.arc()({
    innerRadius: gauge.innerR - 2,
    outerRadius: gauge.innerR - 1,
    startAngle: valueToAngle(0),
    endAngle: valueToAngle(100),
  });
  g.append('path')
    .attr('d', innerBezel)
    .attr('fill', 'rgba(255, 255, 255, 0.06)');
}

function initGauge() {
  const mount = document.getElementById('gauge-mount');
  if (!mount) return;

  const score = Number(mount.dataset.score);
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  mount.innerHTML = '';

  const gauge: GaugeConfig = { width: 400, height: 240, outerR: 160, innerR: 100, bottomPad: 30 };
  const cx = gauge.width / 2;
  const cy = gauge.height - gauge.bottomPad;

  const currentZone = ZONES.find(z => score >= z.start && score < z.end) ?? ZONES[1];

  const svg = d3.select(mount)
    .append('svg')
    .attr('viewBox', `0 0 ${gauge.width} ${gauge.height}`)
    .attr('aria-hidden', 'true')
    .style('width', '100%')
    .style('height', 'auto');

  const defs = svg.append('defs');
  createSvgFilters(defs);

  const g = svg.append('g')
    .attr('transform', `translate(${cx},${cy})`);

  // Animation timing
  const arcDuration = prefersReducedMotion ? 0 : 600;
  const arcStagger = prefersReducedMotion ? 0 : 120;
  const needleDelay = prefersReducedMotion ? 0 : ZONES.length * arcStagger + arcDuration;
  const needleDuration = prefersReducedMotion ? 0 : 1200;

  drawTrack(g, gauge);
  drawZoneArcs(g, gauge, currentZone.label, prefersReducedMotion, arcStagger, arcDuration);
  drawBezelRings(g, gauge);
  drawTickMarks(g, gauge, prefersReducedMotion, needleDelay);
  drawNeedle(g, gauge, score, currentZone.color, prefersReducedMotion, needleDelay, needleDuration);
  drawLabels(g, gauge);

  const markerBaseDelay = needleDelay + needleDuration + 400;
  drawBenchmarkMarkers(g, gauge, mount.dataset.benchmarks, prefersReducedMotion, markerBaseDelay);

  // Signal gauge animation complete
  const totalAnimTime = prefersReducedMotion ? 0 : needleDelay + needleDuration + 600;
  setTimeout(() => {
    window.dispatchEvent(new CustomEvent('gauge-animation-complete'));
  }, totalAnimTime);
}

// Run on first load
initGauge();
// Re-run after View Transitions swap
document.addEventListener('astro:after-swap', initGauge);
</script>
