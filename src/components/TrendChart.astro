<script>
import Chart from 'chart.js/auto';

function initTrendChart() {
  const canvas = document.getElementById('trend-chart') as HTMLCanvasElement;
  if (!canvas) return;

  // Destroy existing chart instance if navigating back via View Transitions
  const existing = Chart.getChart(canvas);
  if (existing) existing.destroy();

  const labels: string[] = JSON.parse(canvas.dataset.labels!);
  const values: number[] = JSON.parse(canvas.dataset.values!);
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const displayLabels = labels.map(d => {
    const date = new Date(d + 'T00:00:00');
    return String(date.getFullYear());
  });

  // Custom plugin: draw colored zone bands behind the chart data
  const zoneBandsPlugin = {
    id: 'zoneBands',
    beforeDraw(chart: Chart) {
      const { ctx, chartArea, scales: { y } } = chart;
      if (!chartArea) return;
      const { left, right } = chartArea;

      const zones = [
        { min: 0, max: 25, color: 'rgba(64, 145, 108, 0.07)' },   // Stable
        { min: 25, max: 50, color: 'rgba(244, 162, 97, 0.07)' },   // Elevated
        { min: 50, max: 75, color: 'rgba(231, 111, 81, 0.07)' },   // Crisis
        { min: 75, max: 100, color: 'rgba(193, 18, 31, 0.07)' },   // Revolution
      ];

      zones.forEach(zone => {
        const yTop = y.getPixelForValue(zone.max);
        const yBottom = y.getPixelForValue(zone.min);
        ctx.fillStyle = zone.color;
        ctx.fillRect(left, yTop, right - left, yBottom - yTop);
      });
    }
  };

  function createChart() {
    // Guard against double-creation if observer fires after a swap
    if (Chart.getChart(canvas)) return;

    new Chart(canvas, {
      type: 'line',
      data: {
        labels: displayLabels,
        datasets: [{
          label: 'Revolution Index Score',
          data: values,
          borderColor: '#e85d04',
          backgroundColor: 'rgba(232, 93, 4, 0.1)',
          tension: 0.3,
          fill: true,
          pointRadius: 1.5,
          pointBackgroundColor: '#e85d04',
        }]
      },
      plugins: [zoneBandsPlugin],
      options: {
        responsive: true,
        maintainAspectRatio: true,
        animation: {
          duration: prefersReducedMotion ? 0 : 1200,
          easing: 'easeOutQuart',
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            mode: 'index',
            intersect: false,
            backgroundColor: '#1a1a1a',
            titleColor: '#f5f5f5',
            bodyColor: '#f5f5f5',
            borderColor: '#333',
            borderWidth: 1,
            callbacks: {
              title: function(context: {dataIndex: number}[]) {
                const idx = context[0].dataIndex;
                const date = new Date(labels[idx] + 'T00:00:00');
                return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
              }
            }
          }
        },
        scales: {
          x: {
            ticks: {
              maxTicksLimit: 6,
              color: '#a0a0a0',
            },
            grid: {
              color: 'rgba(255, 255, 255, 0.05)',
            }
          },
          y: {
            min: 0,
            max: 100,
            ticks: {
              stepSize: 25,
              color: '#a0a0a0',
            },
            grid: {
              color: 'rgba(255, 255, 255, 0.05)',
            }
          }
        }
      }
    });
  }

  // Trigger chart creation when scrolled into view
  const container = document.getElementById('trend-chart-container');
  if (container && !prefersReducedMotion) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            createChart();
            observer.disconnect();
          }
        });
      },
      { threshold: 0.2 }
    );
    observer.observe(container);
  } else {
    // Immediate creation if reduced motion or no container
    createChart();
  }
}

initTrendChart();
document.addEventListener('astro:after-swap', initTrendChart);
</script>
