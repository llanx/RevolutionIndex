# Get your free API key at: https://fred.stlouisfed.org/docs/api/api_key.html
# 1. Create account or log in
# 2. Request API key (instant approval)
# 3. Copy your key below and rename this file to .env
FRED_API_KEY=your_api_key_here

# Optional: ACLED protest data (free registration at https://acleddata.com/)
ACLED_API_KEY=your_acled_key_here
ACLED_EMAIL=your_email_here
