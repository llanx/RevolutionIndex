{
  "mcpServers": {
    "us-gov-open-data": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "us-gov-open-data-mcp"],
      "env": {
        "FRED_API_KEY": "${FRED_API_KEY}",
        "CENSUS_API_KEY": "${CENSUS_API_KEY}",
        "BEA_API_KEY": "${BEA_API_KEY}",
        "BLS_API_KEY": "${BLS_API_KEY}",
        "DATA_GOV_API_KEY": "${DATA_GOV_API_KEY}"
      }
    }
  }
}
