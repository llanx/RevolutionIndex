# Revolution Index — API Keys for US Government Open Data MCP Server
# Copy this file to .env and fill in your keys.
#
# The MCP server works without keys for some endpoints (Treasury, CDC, FDA, etc.)
# but keys unlock higher rate limits and additional datasets.

# Federal Reserve Economic Data (GDP, unemployment, CPI, interest rates)
# Get key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# US Census Bureau (population, demographics, income, housing)
# Get key: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Bureau of Economic Analysis (state GDP, personal income, GDP by industry)
# Get key: https://apps.bea.gov/API/signup/
BEA_API_KEY=

# Bureau of Labor Statistics (employment, wages, CPI breakdowns)
# Get key: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# Data.gov (Congress, FEC, FBI, NOAA, College Scorecard, NREL, and more)
# Get key: https://api.data.gov/signup/
DATA_GOV_API_KEY=

# ACLED (Armed Conflict Location & Event Data -- protest/riot events)
# Register free at https://acleddata.com/ then use your login credentials
ACLED_EMAIL=
ACLED_PASSWORD=
